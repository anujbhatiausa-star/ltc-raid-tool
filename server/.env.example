# Copy this file to server/.env and fill in your values.
# Never commit server/.env to source control.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

OPENAI_API_KEY=sk-...

PORT=3001

# The deployed Vercel URL — used in CORS allow-list.
# For local dev this is optional; localhost:5173 is always allowed.
CLIENT_URL=https://your-app.vercel.app
