# Copy this file to client/.env and fill in your values.
# Never commit client/.env to source control.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Leave blank for local dev — the Vite proxy will forward /api to localhost:3001.
# Set to your Render URL when deploying.
VITE_API_URL=
